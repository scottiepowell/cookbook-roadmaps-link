ORIGIN=https://cookbook.roadmaps.link
CLOUDFLARE_TUNNEL_TOKEN=replace_me
PUID=1000
PGID=1000

# Local AI sidecar runtime profile. Copy selected values into ignored .env.
# OPENAI_API_KEY stays blank here and must never be committed.
AI_PROVIDER=openai
AI_MODEL=gpt-5.4-nano
AI_MAX_OUTPUT_TOKENS=300
AI_TIMEOUT_SECONDS=60
AI_RETRIEVAL_CACHE_ENABLED=true
AI_RETRIEVAL_CACHE_MAX_ENTRIES=128
AI_RETRIEVAL_CACHE_TTL_SECONDS=900
RECIPE_DATASET_DIR=recipe-dataset
RECIPE_DATASET_INDEX_LIMIT=100
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_ENABLE_LIVE_TESTS=true
OPENAI_LIVE_TEST_BUDGET_CENTS=25
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=
